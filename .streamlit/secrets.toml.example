# DeckGen AI — secrets template
# ------------------------------------------------------------------
# LOCAL DEV:
#   1. Copy this file to  .streamlit/secrets.toml   (that real file is gitignored)
#   2. Paste your real LLMFoundry token below.
#
# STREAMLIT CLOUD:
#   Do NOT commit the real token. Instead paste the same keys into
#   App -> Settings -> Secrets in the Streamlit dashboard.
#
# If no token is present, the app still works and falls back to the
# built-in template narrative (no LLM call).
# ------------------------------------------------------------------

# Your LLMFoundry bearer token (used as: Authorization: Bearer <token>)
LLMFOUNDRY_TOKEN = "paste-your-llmfoundry-token-here"

# Optional overrides (defaults shown)
LLMFOUNDRY_BASE_URL = "https://llmfoundry.straive.com/openai/v1"
LLMFOUNDRY_MODEL = "gpt-4o-mini"
